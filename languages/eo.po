#: views/admin/plugin/stats-config-form.php
msgid "User Agent Parser"
msgstr "Analizilo de uzant-agento"

#: views/admin/plugin/stats-config-form.php
#, php-format
msgid "The plugin can parse raw user-agent strings into structured data (browser, OS, device type) using the %sua-parser-js%s library."
msgstr "La kromaĵo povas analizi krudajn uzant-agentajn ĉenojn en strukturitajn datumojn (retumilo, OS, tipo de aparato) per la biblioteko %sua-parser-js%s."

#: views/admin/plugin/stats-config-form.php
msgid "Parsing is done client-side by the visitor's browser and the result is cached server-side, so each unique user-agent string is parsed only once."
msgstr "La analizo estas farata flanke de kliento de la retumilo de la vizitanto kaj la rezulto estas kaŝmemorigita flanke de servilo, do ĉiu unika uzant-agenta ĉeno estas analizita nur unufoje."

#: views/admin/plugin/stats-config-form.php
msgid "Parse on visit"
msgstr "Analizi ĉe vizito"

#: views/admin/plugin/stats-config-form.php
msgid "Automatically parse the visitor's user-agent on each page view and cache the result."
msgstr "Aŭtomate analizi la uzant-agenton de la vizitanto ĉe ĉiu paĝa vido kaj kaŝmemorigi la rezulton."

#: views/admin/plugin/stats-config-form.php
msgid "ua-parser-js URL"
msgstr "URL de ua-parser-js"

#: views/admin/plugin/stats-config-form.php
msgid "URL of the ua-parser-js script to load on public pages."
msgstr "URL de la skripto ua-parser-js por ŝargi en publikaj paĝoj."

#: views/admin/plugin/stats-config-form.php
msgid "Leave empty to use the bundled version shipped with the plugin (recommended for offline / intranet installations)."
msgstr "Lasu malplena por uzi la enbundligitan version liverita kun la kromaĵo (rekomendita por eksterreta / intrareta instalado)."

